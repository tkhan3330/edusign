# ════════════════════════════════════════════════════════
#  EduSign Frontend — Environment Variables
#  Copy this to .env for local dev, or set in Vercel dashboard
# ════════════════════════════════════════════════════════

# Backend API URL.
# LOCAL DEV: leave blank — CRA proxy in package.json handles it.
# PRODUCTION (Vercel): set to your Railway backend URL.
# e.g. https://edusign-backend-production.up.railway.app/api
REACT_APP_API_URL=
