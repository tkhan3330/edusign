# ════════════════════════════════════════════════════════
#  EduSign Backend — Environment Variables
#  Copy this file to .env and fill in the values
#  NEVER commit .env to git
# ════════════════════════════════════════════════════════

# ── Google Drive Folders ──────────────────────────────
# OPTION A: Single parent folder (legacy)
# PARENT_FOLDER_ID=your_parent_folder_id_here

# OPTION B: Multiple folders (comma-separated)
# PARENT_FOLDER_IDS=folder_id_1,folder_id_2,folder_id_3

# NOTE: Both are OPTIONAL if you use the Setup Wizard.
# The wizard saves folder sources to config.json automatically.

# ── Google Credentials (LOCAL DEVELOPMENT) ────────────
# Path to your service account JSON key file (relative to backend/)
# Used when running locally. Leave blank if using GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account.json

# ── Google Credentials (PRODUCTION / RAILWAY) ─────────
# Paste the ENTIRE contents of service-account.json as a single-line string.
# Example: {"type":"service_account","project_id":"...","private_key":"..."}
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Authentication ────────────────────────────────────
# OPTIONAL: Set a password via env var (overrides config.json password)
# If omitted, use the Setup Wizard to set a password.
# ADMIN_PASSWORD=your_secure_password_here

# ── Server ────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────
# Your frontend URL. In production, set to your Vercel URL.
FRONTEND_URL=http://localhost:3000

# ── Advanced ─────────────────────────────────────────
# Custom path for config.json (default: backend/config.json)
# CONFIG_PATH=./config.json
